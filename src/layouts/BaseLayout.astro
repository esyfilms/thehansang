---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Everything Korea, for Singapore.", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const logo = "/logo-soban-leg.svg";
const links = {
  home: "/",
  eat: "/eat/",
  cook: "/cook/",
  travel: "/travel/",
  culture: "/culture/",
  events: "/events/",
  pantry: "/my-pantry/",
  about: "/about/",
  contact: "/contact/",
};

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#F7F3ED">
  <meta name="description" content={description}>
  <title>{title} - The Hansang</title>
  <link rel="canonical" href={canonicalURL}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:site_name" content="The Hansang">
  <meta property="og:type" content="website">
  {image && <meta property="og:image" content={new URL(image, Astro.url)} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Noto+Serif+KR:wght@200;300;400;500&family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <!-- Ad Header - will be populated from Notion Ads DB when sponsors are confirmed -->

  <!-- Navigation - Two-row sticky header like Monocle -->
  <header class="site-header">
    <nav class="nav-bar" aria-label="Main navigation">
      <button type="button" class="nav-hamburger" id="menuOpen" aria-label="Open menu">&#9776;</button>
      <a href={links.home} class="nav-logo">
        <img src={logo} alt="The Hansang" class="nav-logo-img" />
        <span class="nav-wordmark">THE<br>HANSANG</span>
      </a>
      <button type="button" class="nav-search" aria-label="Search the site">Search</button>
    </nav>
    <nav class="nav-categories" aria-label="Content categories">
      <a href={links.eat}>Eat</a>
      <span class="nav-pipe">|</span>
      <a href={links.cook}>Cook</a>
      <span class="nav-pipe">|</span>
      <a href={links.travel}>Travel</a>
      <span class="nav-pipe">|</span>
      <a href={links.culture}>Culture</a>
      <span class="nav-pipe">|</span>
      <a href={links.events}>Events</a>
      <span class="nav-pipe">|</span>
      <a href={links.pantry}>My Pantry</a>
    </nav>
  </header>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
    <button class="mobile-menu-close" id="menuClose" aria-label="Close menu">&times;</button>
    <ul class="mobile-menu-links">
      <li><a href={links.eat}>Eat</a></li>
      <li><a href={links.cook}>Cook</a></li>
      <li><a href={links.travel}>Travel</a></li>
      <li><a href={links.culture}>Culture</a></li>
      <li><a href={links.events}>Events</a></li>
      <li><a href={links.pantry}>My Pantry</a></li>
    </ul>
  </div>

  <main id="main">
    <slot />
  </main>

  <!-- Newsletter -->
  <section class="newsletter" aria-label="Newsletter">
    <h2>The Weekly Hansang</h2>
    <p class="newsletter-sub">New reviews, recipes, and guides every Thursday.</p>
    <p style="font-size: 14px; color: var(--stone); margin-top: 16px; letter-spacing: 0.05em; text-transform: uppercase;">Coming Soon — Under Construction</p>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-col">
      <div class="footer-logo">
        <img src={logo} alt="The Hansang" style="height: 26px; width: auto;">
        <span class="footer-logo-text">THE HANSANG</span>
      </div>
      <div class="footer-tagline">Everything Korea, for Singapore.</div>
    </div>
    <div class="footer-col">
      <h4>Explore</h4>
      <a href={links.eat}>Eat</a>
      <a href={links.cook}>Cook</a>
      <a href={links.travel}>Travel</a>
      <a href={links.culture}>Culture</a>
      <a href={links.events}>Events</a>
    </div>
    <div class="footer-col">
      <h4>More</h4>
      <a href={links.pantry}>My Pantry</a>
      <a href={links.about}>About</a>
      <a href={links.contact}>Contact</a>
      <a href="#">Newsletter</a>
    </div>
    <div class="footer-col">
      <h4>Follow</h4>
      <a href="#">Instagram</a>
      <a href="#">TikTok</a>
      <a href="#">YouTube</a>
      <a href="#">Telegram</a>
    </div>
  </footer>
  <div class="footer-bottom">
    <span>&copy; 2026 The Hansang. All rights reserved.</span>
    <span>Built with care in Singapore.</span>
  </div>

  <script>
    document.getElementById('menuOpen')?.addEventListener('click', () => {
      document.getElementById('mobileMenu')?.classList.add('open');
    });
    document.getElementById('menuClose')?.addEventListener('click', () => {
      document.getElementById('mobileMenu')?.classList.remove('open');
    });
  </script>
</body>
</html>
