              <a class="biz-link" href="#" target="_blank">View on Map &rarr;</a>
            </div>
          </div>

          <!-- AD SLOT between row 1 and row 2 -->
          {pageAd ? (
            pageAd.bannerImages?.[0] ? (
              <a href={pageAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="inline-ad" id="dir-inline-ad" style="display:block;text-align:center;border:none;background:none;">
                <img src={pageAd.bannerImages[0]} alt={pageAd.sponsorName || 'Partner'} style="max-width:728px;width:100%;height:auto;display:block;margin:0 auto;" />
              </a>
            ) : (
              <a href={pageAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="inline-ad" id="dir-inline-ad" style="display:flex;align-items:center;justify-content:center;gap:10px;text-decoration:none;background:#F7F3ED;border:1px solid #E0D8CE;padding:14px 24px;border-radius:4px;">
                <span style="font-family:'Inter',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#B8432A;">{pageAd.sponsorName}</span>
                <span style="font-family:'Inter',sans-serif;font-size:12px;color:#1C1714;letter-spacing:0.02em;">{pageAd.displayText}</span>
              </a>
            )
          ) : (
            <div class="inline-ad" id="dir-inline-ad">Partner &middot; 728 &times; 90 &middot; Leaderboard</div>
          )}

          <!-- CARD 4 -->
          <div class="biz-card" data-cat="mart">
            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#6B4C3B 0%,#4a3428 60%,#2e1e14 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-mart">Korean Mart</span>
              <h4>Listing Placeholder</h4>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Address placeholder
              </div>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Hours placeholder
              </div>
            </div>
            <div class="biz-card-footer">
