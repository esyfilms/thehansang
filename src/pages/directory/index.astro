          <div class="biz-card" data-cat="mart">
            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#5a4030 0%,#3a2818 60%,#2a180a 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-mart">Korean Mart</span>
              <h4>Listing Placeholder</h4>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Address placeholder
              </div>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Hours placeholder
              </div>
            </div>
            <div class="biz-card-footer">
              <span class="biz-mrt">Jurong East MRT</span>
