---
import BaseLayout from '../../layouts/BaseLayout.astro';
let ads: any[] = [];
try { const m = await import('../../data/ads.json'); ads = m.default || []; } catch(e) { ads = []; }
const pageAd = ads.find((a: any) => Array.isArray(a.placement) ? a.placement.includes('Directory Leaderboard') : a.placement === 'Directory Leaderboard');
const inlineAd = ads.find((a: any) => Array.isArray(a.placement) ? a.placement.includes('Category Inline') : a.placement === 'Category Inline');
const mobileAd = ads.find((a: any) => Array.isArray(a.placement) ? a.placement.includes('Mobile Banner') : a.placement === 'Mobile Banner');
const mobileInlineAd = ads.find((a: any) => Array.isArray(a.placement) ? a.placement.includes('Mobile Inline') : a.placement === 'Mobile Inline');
---

<BaseLayout title="Directory" description="Korean restaurants, cafes, marts, and businesses in Singapore. The Hansang.">

  <!-- ========== MOBILE ========== -->
  <div class="mobile-only">

    <div class="cat-hd">
      <div class="cat-title">Directory</div>
      <div class="cat-sub">Korean restaurants, marts &amp; businesses in Singapore</div>
    </div>

    <div class="filters-mobile">
      <button class="pill on" onclick="filterDirMobile('all', this)">All</button>
      <button class="pill" onclick="filterDirMobile('restaurants', this)">Restaurants</button>
      <button class="pill" onclick="filterDirMobile('korean-marts', this)">Korean Marts</button>
      <button class="pill" onclick="filterDirMobile('butchery', this)">Butchery</button>
      <button class="pill" onclick="filterDirMobile('bakery', this)">Bakery</button>
      <button class="pill" onclick="filterDirMobile('online-shops', this)">Online Shops</button>
    </div>

    <!-- Map -->
    <div class="map-wrap-mobile"><div id="hansang-map-mobile" style="width:100%;height:220px;"></div></div>

    <!-- Directory cards -->
    <a class="dc" href="#" data-mcat="restaurants">
      <div>
        <div class="dc-type">Restaurant</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#c4564a,#8b3d34);"></div>
    </a>

    <a class="dc" href="#" data-mcat="restaurants">
      <div>
        <div class="dc-type">Restaurant</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#4a3a2a,#2e2418);"></div>
    </a>

    <a class="dc" href="#" data-mcat="restaurants">
      <div>
        <div class="dc-type">Restaurant</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#3a4a5a,#2a3a4a);"></div>
    </a>

    <!-- Ad -->
    <div style="padding:12px 18px;">
      {mobileInlineAd ? (
        <a href={mobileInlineAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="ad-rect" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;background:#F7F3ED;border:1px solid #E0D8CE;">
          <span style="font-family:'Inter',sans-serif;font-size:9px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:#B8432A;">{mobileInlineAd.sponsorName}</span>
          <span style="font-family:'Inter',sans-serif;font-size:10px;color:#1C1714;">{mobileInlineAd.displayText}</span>
        </a>
      ) : (
        <div class="ad-rect"><span>Partner &middot; 320&times;100</span></div>
      )}
    </div>

    <a class="dc" href="#" data-mcat="korean-marts">
      <div>
        <div class="dc-type">Korean Mart</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#6B4C3B,#4a3428);"></div>
    </a>

    <a class="dc" href="#" data-mcat="korean-marts">
      <div>
        <div class="dc-type">Korean Mart</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#5a4030,#3a2818);"></div>
    </a>

    <a class="dc" href="#" data-mcat="butchery">
      <div>
        <div class="dc-type">Butchery</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#3a5040,#2a3a2e);"></div>
    </a>

    <a class="dc" href="#" data-mcat="bakery">
      <div>
        <div class="dc-type">Bakery</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#8B6914,#6b5010);"></div>
    </a>

    <a class="dc" href="#" data-mcat="online-shops">
