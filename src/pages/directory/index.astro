          <button class="filter-btn" onclick="filterDir('online', this)">Online Shops</button>
        </div>
      </div>
    </section>

    <!-- ===== DIRECTORY GRID ===== -->
    <section class="filter-section">
      <div class="container">
        <div class="results-info" id="results-count">Showing 9 listings</div>

        <div class="directory-grid" id="dir-grid">

          <!-- CARD 1 -->
          <div class="biz-card" data-cat="restaurant">
            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#c4564a 0%,#8b3d34 60%,#5a2820 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-restaurant">Restaurant</span>
              <h4>Listing Placeholder</h4>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Address placeholder
              </div>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Hours placeholder
              </div>
              <span class="biz-halal">Halal Certified</span>
            </div>
            <div class="biz-card-footer">
              <span class="biz-mrt">Bugis MRT</span>
              <a class="biz-link" href="#" target="_blank">View on Map &rarr;</a>
            </div>
          </div>

          <!-- CARD 2 -->
          <div class="biz-card" data-cat="restaurant">
            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#4a3a2a 0%,#2e2418 60%,#1e180e 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-restaurant">Restaurant</span>
              <h4>Listing Placeholder</h4>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Address placeholder
              </div>
              <div class="biz-meta-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Hours placeholder
              </div>
            </div>
            <div class="biz-card-footer">
              <span class="biz-mrt">Tanjong Pagar MRT</span>
              <a class="biz-link" href="#" target="_blank">View on Map &rarr;</a>
            </div>
          </div>

          <!-- CARD 3 -->
          <div class="biz-card" data-cat="restaurant">
            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#3a4a5a 0%,#2a3a4a 60%,#1a2a3a 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-restaurant">Restaurant</span>
