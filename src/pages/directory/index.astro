            <div class="biz-card-img">
              <div class="img-placeholder" style="background:linear-gradient(145deg,#8B6914 0%,#6b5010 60%,#4a3808 100%);">Photo</div>
            </div>
            <div class="biz-card-body">
              <span class="biz-cat-badge badge-bakery">Bakery</span>
              <h4>Listing Placeholder</h4>
