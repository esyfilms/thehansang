---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Directory" description="Korean restaurants, cafes, marts, and businesses in Singapore.">
  <section class="directory-page">
    <div class="container">
      <h1 class="page-title">Directory</h1>
      <p class="page-subtitle">Korean restaurants, cafes, marts, and businesses in Singapore.</p>
      <p style="text-align:center; color:#999; font-size:14px; letter-spacing:0.05em; text-transform:uppercase; padding:48px 0;">Coming Soon</p>
    </div>
  </section>
</BaseLayout>

<style>
  .directory-page { padding: 56px 0 80px; }
  .page-title {
    font-family: 'EB Garamond', serif;
    font-size: 36px;
    font-weight: 500;
    text-align: center;
    margin-bottom: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  .page-subtitle {
    text-align: center;
    color: #888;
    font-size: 15px;
    margin-bottom: 40px;
  }
</style>
