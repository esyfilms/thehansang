        <div class="dc-type">Online Shop</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#3a5080,#2a3860);"></div>
    </a>

    <a class="dc" href="#" data-mcat="restaurants">
      <div>
        <div class="dc-type">Restaurant</div>
        <div class="dc-name">Listing Placeholder</div>
        <div class="dc-loc">Address placeholder</div>
      </div>
      <div class="dc-img" style="background:linear-gradient(145deg,#6b4a3a,#4a3028);"></div>
    </a>

    <!-- Ad -->
    <div style="padding:12px 18px;">
      {mobileAd ? (
        <a href={mobileAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="ad-rect" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;background:#F7F3ED;border:1px solid #E0D8CE;">
          <span style="font-family:'Inter',sans-serif;font-size:9px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:#B8432A;">{mobileAd.sponsorName}</span>
          <span style="font-family:'Inter',sans-serif;font-size:10px;color:#1C1714;">{mobileAd.displayText}</span>
        </a>
      ) : (
        <div class="ad-rect"><span>Partner &middot; 320&times;100</span></div>
      )}
    </div>

  </div>

  <!-- ========== DESKTOP ========== -->
  <div class="desktop-only">

    <!-- ===== CATEGORY TITLE BAR ===== -->
    <section class="category-title-bar">
      <div class="container">
        <h1>Directory</h1>
        <div class="title-sub">Curated list of Korean restaurants, marts &amp; more in Singapore</div>
      </div>
    </section>

    <!-- ===== MAP SECTION ===== -->
    <section class="map-section">
