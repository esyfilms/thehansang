            <div class="legend-dot" style="background:#B8432A;"></div>
            Restaurants
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#6B4C3B;"></div>
            Korean Marts
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#4a7060;"></div>
            Butchery
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#8B6914;"></div>
            Bakery
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#3a5080;"></div>
            Online Shops
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FILTER BAR ===== -->
    <hr class="section-divider">
    <section class="filter-bar">
      <div class="container">
        <div class="filter-row">
          <span class="filter-row-label">Filter</span>
          <button class="filter-btn active" onclick="filterDir('all', this)">All</button>
