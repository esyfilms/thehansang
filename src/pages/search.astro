---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all articles on The Hansang.">
  <section class="search-page">
    <div class="container">
      <h1 class="search-page-title">Search</h1>
      <div class="search-page-input-wrap">
        <input
          type="text"
          id="searchPageInput"
          class="search-page-input"
          placeholder="Search articles, recipes, reviews..."
          autocomplete="off"
          autofocus
        />
      </div>
      <div id="searchPageResults" class="search-page-results">
        <p class="search-page-hint">Start typing to search articles...</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .search-page {
    padding: 56px 0 80px;
    min-height: 60vh;
  }
  .search-page-title {
    font-family: 'EB Garamond', serif;
    font-size: 36px;
    font-weight: 500;
    text-align: center;
    margin-bottom: 40px;
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  .search-page-input-wrap {
    max-width: 600px;
    margin: 0 auto 48px;
  }
  .search-page-input {
    width: 100%;
    padding: 14px 0;
    border: none;
    border-bottom: 2px solid #1C1714;
    background: transparent;
    font-family: 'Source Serif 4', serif;
    font-size: 22px;
    color: #1C1714;
    outline: none;
  }
  .search-page-input::placeholder {
    color: #bbb;
  }
  .search-page-input:focus {
    border-bottom-color: #B8432A;
  }
  .search-page-results {
    max-width: 800px;
    margin: 0 auto;
  }
  .search-page-hint {
    text-align: center;
    color: #999;
    font-size: 14px;
    padding: 24px 0;
  }
  .search-page-results :global(.search-result-card) {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid #eee;
    text-decoration: none;
    color: #1C1714;
    transition: background-color 0.2s;
  }
  .search-page-results :global(.search-result-card:hover) {
    background: #f9f8f6;
  }
  .search-page-results :global(.search-result-img) {
    width: 120px;
    height: 80px;
    border-radius: 4px;
    background: #E0D8CE;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .search-page-results :global(.search-result-img img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .search-page-results :global(.search-result-pillar) {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B8432A;
    margin-bottom: 4px;
  }
  .search-page-results :global(.search-result-title) {
    font-family: 'Source Serif 4', serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 4px;
  }
  .search-page-results :global(.search-result-excerpt) {
    font-size: 13px;
    color: #888;
    line-height: 1.5;
  }
  .search-page-results :global(.search-result-meta) {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #bbb;
    margin-top: 6px;
  }
  .search-page-results :global(.search-no-results) {
    text-align: center;
    padding: 48px 0;
    color: #999;
    font-size: 15px;
  }

  @media (max-width: 768px) {
    .search-page { padding: 40px 0 60px; }
    .search-page-title { font-size: 28px; }
    .search-page-input { font-size: 18px; }
    .search-page-results :global(.search-result-card) {
      grid-template-columns: 1fr;
    }
    .search-page-results :global(.search-result-img) {
      width: 100%;
      height: 160px;
    }
  }
</style>

<script>
  const input = document.getElementById('searchPageInput') as HTMLInputElement;
  const results = document.getElementById('searchPageResults') as HTMLElement;
  let searchIndex: any[] | null = null;

  // Read ?q= param
  const urlParams = new URLSearchParams(window.location.search);
  const initialQuery = urlParams.get('q');
  if (initialQuery && input) {
    input.value = initialQuery;
    performSearch(initialQuery);
  }

  async function loadSearchIndex() {
    if (searchIndex) return searchIndex;
    try {
      const res = await fetch('/search-index.json');
      searchIndex = await res.json();
      return searchIndex;
    } catch {
      return [];
    }
  }

  async function performSearch(query: string) {
    const q = query.trim().toLowerCase();
    if (q.length < 2) {
      results.innerHTML = '<p class="search-page-hint">Start typing to search articles...</p>';
      return;
    }

    const index = await loadSearchIndex();
    const matches = (index || []).filter((p: any) =>
      p.title?.toLowerCase().includes(q) ||
      p.pillar?.toLowerCase().includes(q) ||
      p.excerpt?.toLowerCase().includes(q) ||
      (p.tags || []).some((t: string) => t.toLowerCase().includes(q))
    );

    if (matches.length === 0) {
      results.innerHTML = `<p class="search-no-results">No articles found for "${query.trim()}"</p>`;
      return;
    }

    results.innerHTML = matches.map((m: any) => `
      <a href="${m.url}" class="search-result-card">
        <div class="search-result-img">
          ${m.coverUrl ? `<img src="${m.coverUrl}" alt="" />` : ''}
        </div>
        <div>
          <div class="search-result-pillar">${m.pillar || ''}</div>
          <div class="search-result-title">${m.title}</div>
          <div class="search-result-excerpt">${m.excerpt || ''}</div>
          <div class="search-result-meta">${m.date || ''}</div>
        </div>
      </a>
    `).join('');
  }

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      performSearch(input.value);
      // Update URL without reload
      const url = new URL(window.location.href);
      if (input.value.trim()) {
        url.searchParams.set('q', input.value.trim());
      } else {
        url.searchParams.delete('q');
      }
      history.replaceState(null, '', url.toString());
    }, 200);
  });
</script>
