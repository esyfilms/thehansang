  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-sidebar { border-left: none; padding-left: 0; border-top: 2px solid #eee; padding-top: 32px; }
  }
  @media (max-width: 768px) {
    /* Hero */
    .article-hero { height: 220px; max-width: none; }
    .article-hero .hero-overlay { position: absolute; top: 0; transform: none; padding: 16px 18px; display: flex; flex-direction: column; justify-content: flex-end; }
    .hero-overlay .breadcrumb { font-size: 10px; letter-spacing: 0.09em; margin-bottom: 5px; }
    .hero-overlay .pillar-tag { display: inline-block; font-size: 9px; letter-spacing: 0.11em; background: rgba(255,255,255,0.11); padding: 3px 7px; border-radius: 2px; margin-bottom: 6px; }
    .hero-overlay h1 { font-size: 18px; font-weight: 500; line-height: 1.3; margin-bottom: 3px; max-width: none; }
    .hero-overlay .subtitle { font-family: 'Source Serif 4', serif; font-style: italic; font-size: 12px; color: rgba(255,255,255,0.6); max-width: none; line-height: 1.4; }

    /* Meta bar */
    .article-meta-bar { max-width: none; padding: 11px 18px; border-bottom-width: 1px; flex-direction: row; gap: 0; }
    .meta-left { font-size: 11px; letter-spacing: 0; text-transform: none; color: #888; }
    .meta-left span { margin-right: 6px; }
    .share-label { display: none; }
    .share-btn { width: 24px; height: 24px; font-size: 10px; }

    /* Layout */
    .article-layout { max-width: none; padding: 0; grid-template-columns: 1fr; gap: 0; }
    .article-sidebar { display: none; }
    .article-body { max-width: none; padding: 16px 18px; }
    .article-body p { font-size: 15px; line-height: 1.75; margin-bottom: 13px; }

    /* Recipe meta grid */
    .recipe-meta-grid { margin-bottom: 16px; border-radius: 3px; }
    .rmc { padding: 9px 11px; }
    .rmv { font-size: 15px; }
