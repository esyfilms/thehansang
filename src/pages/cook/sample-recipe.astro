<script>
  document.querySelectorAll('.ingredient-check').forEach(function(check) {
    function toggle() {
      var li = check.parentElement;
      var isChecked = li.classList.toggle('checked');
      check.setAttribute('aria-checked', isChecked);
    }
    check.addEventListener('click', toggle);
    check.addEventListener('keydown', function(e) {
      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggle(); }
    });
  });
</script>
