    .info-item:last-child { border-bottom: none; }
    .info-item .info-label { font-size: 12px; letter-spacing: 0; text-transform: none; color: #888; margin-bottom: 0; }
    .info-item .info-value { font-size: 12px; font-weight: 400; }
    .ig-embed { padding: 16px; margin: 16px 0; }
    .ig-placeholder { height: 200px; }
    .article-tags { padding-top: 16px; border-top-width: 1px; margin-top: 16px; }
    .tags-label { font-size: 9px; letter-spacing: 0.13em; color: #bbb; margin-bottom: 8px; }
    .tag { font-size: 10px; padding: 4px 10px; border-radius: 12px; border-color: #e0e0e0; }
    .more-articles { max-width: none; padding: 0 0 18px; }
    .more-articles .section-header { padding: 16px 18px 14px; border-top: 4px solid #6B4C3B; }
    .more-articles .section-header h3 { font-size: 11px; }
    .more-articles .section-header a { display: none; }
    .more-grid { grid-template-columns: 1fr 1fr; gap: 12px; padding: 0 18px; }
    .more-img { height: auto; aspect-ratio: 4/3; }
    .more-card h4 { font-size: 13px; }
    .more-tag { font-size: 9px; }
    .ad-space { margin: 0 18px 18px; height: 90px; border: 1px dashed #ccc; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #bbb; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 0; }
  }
</style>
