---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Travel" description="Travel — Korea travel guides, neighbourhood itineraries, and food district maps for Singaporeans. The Hansang.">

  <!-- Launch Banner -->
  <div class="launch-banner">
    We're launching soon — this is a design preview
  </div>

  <header class="page-header">
    <div class="page-header-inner">
      <div class="page-header-korean" lang="ko" aria-hidden="true">여행</div>
      <h1>Travel</h1>
      <p class="page-header-desc">Korea travel guides, neighbourhood itineraries, food district maps, and practical tips written for Singaporeans planning their next trip.</p>
    </div>
  </header>

  <!-- Filter Bar -->
  <div class="filter-bar">
    <button class="filter-btn active">All</button>
    <button class="filter-btn">Seoul</button>
    <button class="filter-btn">Busan</button>
    <button class="filter-btn">Jeju</button>
    <button class="filter-btn">Itineraries</button>
    <button class="filter-btn">Food Maps</button>
  </div>

  <!-- Featured Article -->
  <div class="cat-featured">
    <div class="cat-featured-image">[ Featured Image ]</div>
    <div class="cat-featured-text">
      <div class="cat-featured-pillar">Travel &middot; Guide</div>
      <h2 class="cat-featured-title">Featured Travel Guide Title Placeholder</h2>
      <p class="cat-featured-excerpt">Short description placeholder text goes here. This will be replaced with a real travel guide excerpt when content is published.</p>
      <span class="cat-featured-meta">Coming Soon</span>
    </div>
  </div>

  <!-- Article Grid -->
  <section class="cat-grid-section">
    <div class="cat-grid">
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Guide</div>
        <div class="cat-card-title">Guide Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Itinerary</div>
        <div class="cat-card-title">Itinerary Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Food Map</div>
        <div class="cat-card-title">Article Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Guide</div>
        <div class="cat-card-title">Guide Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Tips</div>
        <div class="cat-card-title">Article Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
      <div class="cat-card" style="cursor:default;">
        <div class="cat-card-image">[ Image ]</div>
        <div class="cat-card-pillar">Travel &middot; Itinerary</div>
        <div class="cat-card-title">Itinerary Title Placeholder</div>
        <div class="cat-card-excerpt">Description placeholder text goes here.</div>
        <div class="cat-card-meta">Coming Soon</div>
      </a>
    </div>
  </section>

  <!-- Pagination -->
  <nav class="pagination" aria-label="Pagination">
    <span class="pagination-btn disabled">&larr; Previous</span>
    <span class="pagination-page active">1</span>
    <span class="pagination-page">2</span>
    <span class="pagination-btn disabled">Next &rarr;</span>
  </nav>

</BaseLayout>

<style>
  .launch-banner { background: var(--ink); color: var(--cream); text-align: center; padding: 10px 24px; font-size: 13px; letter-spacing: 0.05em; }
  .page-header { padding: 64px 48px 48px; border-bottom: 1px solid var(--stone); animation: fadeUp 0.6s ease-out 0.1s both; }
  .page-header-inner { max-width: 640px; }
  .page-header-korean { font-family: 'Noto Serif KR', serif; font-size: 56px; font-weight: 200; line-height: 1; color: var(--stone); margin-bottom: 4px; }
  .page-header h1 { font-family: 'Source Serif 4', serif; font-size: 44px; font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  .page-header-desc { font-size: 16px; color: var(--gray-500); line-height: 1.7; max-width: 520px; }
  .filter-bar { padding: 16px 48px; border-bottom: 1px solid var(--stone); display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; animation: fadeUp 0.6s ease-out 0.15s both; }
  .filter-bar::-webkit-scrollbar { display: none; }
  .filter-btn { font-family: 'Outfit', sans-serif; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; padding: 8px 20px; border: 1px solid var(--stone); background: none; color: var(--gray-500); cursor: pointer; white-space: nowrap; transition: all 0.2s; }
  .filter-btn:hover { border-color: var(--ink); color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .cat-featured { display: grid; grid-template-columns: 3fr 2fr; border-bottom: 1px solid var(--stone); animation: fadeUp 0.6s ease-out 0.2s both; }
  .cat-featured-image { background: var(--stone); min-height: 360px; display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--gray-400); }
  .cat-featured-text { padding: 48px; display: flex; flex-direction: column; justify-content: center; }
  .cat-featured-pillar { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 16px; }
  .cat-featured-title { font-family: 'Source Serif 4', serif; font-size: 28px; font-weight: 700; line-height: 1.25; margin-bottom: 12px; }
  .cat-featured-excerpt { font-size: 16px; color: var(--gray-500); line-height: 1.65; margin-bottom: 16px; }
  .cat-featured-meta { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray-400); }
  .cat-grid-section { padding: 32px 48px 48px; animation: fadeUp 0.6s ease-out 0.25s both; }
  .cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid var(--stone); }
  .cat-card { display: block; padding: 32px 28px; border-bottom: 1px solid var(--stone); text-decoration: none; color: var(--ink); transition: background 0.2s; }
  .cat-card:nth-child(odd) { border-right: 1px solid var(--stone); }
  .cat-card:hover { background: var(--linen); }
  .cat-card-image { width: 100%; aspect-ratio: 16 / 10; background: var(--stone); margin-bottom: 16px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--gray-400); }
  .cat-card-pillar { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 8px; }
  .cat-card-title { font-family: 'Source Serif 4', serif; font-size: 20px; font-weight: 600; line-height: 1.3; margin-bottom: 8px; }
  .cat-card-excerpt { font-size: 15px; color: var(--gray-500); line-height: 1.6; }
  .cat-card-meta { font-size: 11px; color: var(--gray-400); letter-spacing: 0.06em; text-transform: uppercase; margin-top: 12px; }
  .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; padding: 32px 48px 64px; }
  .pagination-btn, .pagination-page { font-family: 'Outfit', sans-serif; font-size: 12px; letter-spacing: 0.06em; padding: 8px 16px; border: 1px solid var(--stone); color: var(--gray-500); cursor: default; }
  .pagination-btn.disabled { opacity: 0.4; }
  .pagination-page.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  @media (max-width: 768px) {
    .page-header { padding: 40px 24px 36px; } .page-header-korean { font-size: 40px; } .page-header h1 { font-size: 32px; }
    .filter-bar { padding: 12px 24px; } .cat-featured { grid-template-columns: 1fr; } .cat-featured-image { min-height: 220px; } .cat-featured-text { padding: 28px 24px; }
    .cat-grid-section { padding: 24px 24px 36px; } .cat-grid { grid-template-columns: 1fr; } .cat-card:nth-child(odd) { border-right: none; } .cat-card { padding: 24px 0; }
    .pagination { padding: 24px 24px 48px; }
  }
  @media (max-width: 480px) { .page-header-korean { font-size: 32px; } .page-header h1 { font-size: 26px; } }
</style>
