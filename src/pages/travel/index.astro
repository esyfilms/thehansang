---
import BaseLayout from '../../layouts/BaseLayout.astro';
let ads: any[] = [];
try { const m = await import('../../data/ads.json'); ads = m.default || []; } catch(e) { ads = []; }
const pageAd = ads.find((a: any) => a.placement === 'Travel Leaderboard');
const inlineAd = ads.find((a: any) => a.placement === 'Category Inline');
---

<BaseLayout title="Travel" description="Travel: Korea travel guides, neighbourhood itineraries, and food district maps for Singaporeans. The Hansang.">

  <!-- ==================== MOBILE LAYOUT ==================== -->
  <div class="mobile-only">

    <!-- Category Header -->
    <div class="cat-hd">
      <div class="cat-title">Travel</div>
      <div class="cat-sub">Korea travel guides written for Singaporeans</div>
    </div>

    <!-- Filter Pills -->
    <div class="filters-mobile">
      <button class="pill on">All</button>
      <button class="pill">Seoul</button>
      <button class="pill">Busan</button>
      <button class="pill">Jeju</button>
      <button class="pill">Day Trips</button>
      <button class="pill">Planning</button>
    </div>

    <!-- Hero Card -->
    <a class="ch1" href="/travel/seoul-5-days/">
      <div>
        <div class="ptag">Featured &middot; Travel</div>
        <div class="ch1-title">Article Title Placeholder</div>
        <div class="ch1-meta">Coming Soon</div>
      </div>
      <div class="ch1-img" style="background:linear-gradient(145deg,#4a6b5a 0%,#2e4a3a 50%,#1e3028 100%);"></div>
    </a>

    <!-- Korea Guides Section -->
    <div class="sh"><span class="sh-lbl">Korea Guides</span><a class="sh-lnk" href="#">More &rarr;</a></div>

    <div class="kg-scroll">
      <!-- Seoul Eats -->
      <a class="kg-dest" href="/travel/seoul-eats/" style="background:linear-gradient(145deg,#c4564a 0%,#8b3d34 60%,#5a2820 100%);">
        <div class="kg-dest-hd">
          <div class="kg-dest-lbl">The Hansang Korea Guide</div>
          <div class="kg-dest-rule"></div>
          <div class="kg-dest-name">Seoul Eats</div>
          <div class="kg-dest-desc">Best dishes, restaurants &amp; hidden eats in the city</div>
        </div>
        <div class="kg-dest-img" style="background:linear-gradient(180deg,transparent,rgba(0,0,0,0.2));"></div>
        <div class="kg-dest-ft">
          <span class="kg-dest-cta">Explore &rarr;</span>
          <span class="kg-dest-cnt">12 articles</span>
        </div>
      </a>

      <!-- Seoul Cafe -->
      <a class="kg-dest" href="/travel/seoul-cafe/" style="background:linear-gradient(145deg,#c4a882 0%,#8b7550 60%,#5a4a30 100%);">
        <div class="kg-dest-hd">
          <div class="kg-dest-lbl">The Hansang Korea Guide</div>
          <div class="kg-dest-rule"></div>
          <div class="kg-dest-name">Seoul Cafe</div>
          <div class="kg-dest-desc">Coffee culture, themed cafes &amp; the best bingsu spots</div>
        </div>
        <div class="kg-dest-img" style="background:linear-gradient(180deg,transparent,rgba(0,0,0,0.2));"></div>
        <div class="kg-dest-ft">
          <span class="kg-dest-cta">Explore &rarr;</span>
          <span class="kg-dest-cnt">8 articles</span>
        </div>
      </a>

      <!-- Seoul Visit -->
      <a class="kg-dest" href="/travel/seoul-visit/" style="background:linear-gradient(145deg,#4a6b5a 0%,#2e4a3a 60%,#1e3028 100%);">
        <div class="kg-dest-hd">
          <div class="kg-dest-lbl">The Hansang Korea Guide</div>
          <div class="kg-dest-rule"></div>
          <div class="kg-dest-name">Seoul Visit</div>
          <div class="kg-dest-desc">Neighbourhoods, temples &amp; the spots every visitor needs</div>
        </div>
        <div class="kg-dest-img" style="background:linear-gradient(180deg,transparent,rgba(0,0,0,0.2));"></div>
        <div class="kg-dest-ft">
          <span class="kg-dest-cta">Explore &rarr;</span>
          <span class="kg-dest-cnt">10 articles</span>
        </div>
      </a>

      <!-- Seoul Shops -->
      <a class="kg-dest" href="/travel/seoul-shops/" style="background:linear-gradient(145deg,#6b5a8c 0%,#4a3a6b 60%,#2e2448 100%);">
        <div class="kg-dest-hd">
          <div class="kg-dest-lbl">The Hansang Korea Guide</div>
          <div class="kg-dest-rule"></div>
          <div class="kg-dest-name">Seoul Shops</div>
          <div class="kg-dest-desc">Street markets, Dongdaemun, local brands &amp; K-beauty hauls</div>
