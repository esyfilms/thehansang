          <div class="kg-header">
            <div class="kg-label">The Hansang Korea Guide</div>
            <div class="kg-divider"></div>
            <h4>Seoul Shops</h4>
            <p class="kg-desc">Street markets, Dongdaemun, local brands &amp; K-beauty hauls</p>
          </div>
          <div class="kg-img">
            <div class="img-placeholder" style="background:linear-gradient(145deg,#6b5a8c 0%,#4a3a6b 60%,#2e2448 100%);">Seoul Shops</div>
          </div>
          <div class="kg-footer">
            <span class="kg-cta">Explore &rarr;</span>
            <span class="kg-count">7 articles</span>
          </div>
        </a>

        <!-- CARD 5: Seoul Recommendation -->
        <a href="/travel/seoul-nights/" class="korea-guide-card">
          <div class="kg-header">
            <div class="kg-label">The Hansang Korea Guide</div>
            <div class="kg-divider"></div>
            <h4>Seoul Recommendation</h4>
            <p class="kg-desc">Eric's personal picks: the places he keeps going back to</p>
          </div>
          <div class="kg-img">
            <div class="img-placeholder" style="background:linear-gradient(145deg,#8c6b4a 0%,#6b4a2e 60%,#4a2e18 100%);">Seoul Recs</div>
          </div>
          <div class="kg-footer">
            <span class="kg-cta">Explore &rarr;</span>
            <span class="kg-count">9 articles</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Section Divider -->
  <hr class="section-divider">

  <!-- Results Info -->
  <div class="container"><div class="results-info" id="results-count">Showing 9 articles</div></div>

  <!-- Article Grid -->
  <section class="dt-container">
    <div class="article-grid">

      <a href="#" class="card" data-cat="seoul-eats" style="text-decoration:none;color:inherit;">
        <div class="card-img"><div class="img-placeholder" style="background:linear-gradient(145deg,#c4564a,#8b3d34);">Photo</div></div>
        <div class="card-tag">Travel &middot; Guide</div>
        <h4>Article Title Placeholder</h4>
        <div class="card-meta">Coming Soon</div>
      </a>

      <a href="#" class="card" data-cat="seoul-cafe" style="text-decoration:none;color:inherit;">
        <div class="card-img"><div class="img-placeholder" style="background:linear-gradient(145deg,#c4a882,#8b7550);">Photo</div></div>
        <div class="card-tag">Travel &middot; Guide</div>
