<style>
  /* ===== DESKTOP CONTENT CONTAINER ===== */
  .dt-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ===== PLACEHOLDER IMAGES ===== */
  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.35);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ===== CATEGORY TITLE BAR (Monocle dark band) ===== */
  .category-title-bar {
    background: #FFFFFF;
    padding: 16px 0;
  }
  .category-title-bar .dt-container {
    background: var(--ink);
    padding-top: 28px;
    padding-bottom: 28px;
  }
  .category-title-bar h1 {
    font-family: 'Source Serif 4', serif;
    font-size: 32px;
    font-weight: 600;
    color: #FFFFFF;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .category-title-bar .title-sub {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    font-weight: 300;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-top: 6px;
  }

  /* ===== CATEGORY HERO (featured article) ===== */
  .category-hero .dt-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding-top: 48px;
    padding-bottom: 48px;
    align-items: center;
  }
  .category-hero-img {
    border-radius: 4px;
    height: 320px;
    overflow: hidden;
  }
  .category-hero-text .pillar-tag {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: 14px;
  }
  .category-hero-text h2 {
    font-family: 'Source Serif 4', serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .category-hero-text p {
    font-size: 14px;
    color: #888;
    line-height: 1.65;
  }
  .category-hero-text .meta {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #bbb;
  }

  /* ===== AD LEADERBOARD ===== */
  .ad-leaderboard {
    padding: 16px 0;
    background: #FFFFFF;
  }
  .ad-leaderboard-inner {
    height: 90px;
    border: 1px dashed #ccc;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #bbb;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ===== KOREA GUIDE SECTION HEADER ===== */
  .korea-guide-section {
    padding: 48px 0;
  }
  .korea-guide-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
    padding-bottom: 16px;
  }
  .korea-guide-header-title {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .korea-guide-header-sub {
    font-family: 'Source Serif 4', serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    margin-top: 6px;
  }
  .korea-guide-more {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ember);
    text-decoration: none;
  }

  /* ===== KOREA GUIDE CARDS (6-col grid: 3 top, 2 centered bottom) ===== */
  .korea-guide-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
    padding-bottom: 48px;
  }
  .korea-guide-card {
    grid-column: span 2;
    background: #6B8C7A;
    display: flex;
    flex-direction: column;
    min-height: 400px;
    text-decoration: none;
    border-radius: 14px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .korea-guide-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  }
