<script is:inline>
function filterTravel(cat) {
  // Highlight active guide card
  document.querySelectorAll('.korea-guide-card').forEach(function(c) { c.classList.remove('active'); });
  if (cat !== 'all' && event && event.currentTarget) {
    event.currentTarget.classList.add('active');
  }
  // Filter article grid
  var cards = document.querySelectorAll('.article-grid .card');
  var visible = 0;
  cards.forEach(function(card) {
    if (cat === 'all' || card.dataset.cat === cat) { card.style.display = ''; visible++; }
    else { card.style.display = 'none'; }
  });
  var el = document.getElementById('results-count');
  if (el) el.textContent = 'Showing ' + visible + ' article' + (visible !== 1 ? 's' : '');
  // Scroll to grid
  var grid = document.querySelector('.article-grid');
  if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
  // Hide inline ad when filtered
  var ad = document.querySelector('.inline-ad');
  if (ad) ad.style.display = (cat === 'all') ? '' : 'none';
}

function filterTravelMobile(cat) {
  var cards = document.querySelectorAll('.mobile-only .lc');
  cards.forEach(function(card) {
    if (cat === 'all' || card.dataset.mcat === cat) { card.style.display = ''; }
    else { card.style.display = 'none'; }
  });
}
</script>
