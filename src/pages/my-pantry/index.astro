<style>
  /* ===== CATEGORY TITLE BAR ===== */
  .category-title-bar { background: #FFFFFF; padding: 16px 0; }
  .category-title-bar .container { background: #1C1714; padding-top: 28px; padding-bottom: 28px; }
  .category-title-bar h1 {
    font-family: 'Source Serif 4', serif;
    font-size: 32px;
    font-weight: 600;
    color: #FFFFFF;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .category-title-bar .title-sub {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-top: 6px;
  }

  /* ===== SECTION DIVIDER ===== */
  .section-divider { border: none; border-top: 2px solid #eee; max-width: 1020px; margin: 0 auto; }

  /* ===== SECTION HEADER ===== */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 32px 0 16px;
  }
  .section-header h3 {
    font-family: 'Source Serif 4', serif;
    font-size: 20px;
    font-weight: 500;
    color: #1C1714;
  }
  .section-header a {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B8432A;
    text-decoration: none;
  }

  /* ===== PLACEHOLDER IMAGES ===== */
  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,0.15);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.4s ease;
  }

  /* ===== FEATURED PICKS ===== */
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    padding-bottom: 40px;
  }
  .featured-product {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
    position: relative;
  }
  .featured-product:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.08); border-color: #ddd; }
  .featured-product .fp-img {
    height: 220px;
    overflow: hidden;
    background: #f7f3ed;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .featured-product:hover .fp-img .img-placeholder { transform: scale(1.03); }
  .featured-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: #B8432A;
    color: #FFFFFF;
    padding: 3px 8px;
    border-radius: 3px;
  }
  .fp-body { padding: 18px 18px 14px; }
  .fp-brand {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B8432A;
    margin-bottom: 6px;
  }
  .fp-name {
    font-family: 'Source Serif 4', serif;
    font-size: 17px;
    font-weight: 500;
    color: #1C1714;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .fp-desc { font-size: 12px; color: #888; line-height: 1.6; margin-bottom: 12px; }
  .fp-footer {
    padding: 12px 18px;
    border-top: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .fp-price {
    font-family: 'Source Serif 4', serif;
    font-size: 15px;
    font-weight: 500;
    color: #1C1714;
  }
  .fp-price .fp-price-note { font-size: 10px; color: #bbb; font-family: 'Inter'; font-weight: 300; }
  .fp-cta {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: #1C1714;
    color: #FFFFFF;
    padding: 8px 14px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .fp-cta:hover { background: #B8432A; }

  /* ===== FILTER BAR ===== */
  .filter-bar { padding: 8px 0 0; }
  .filter-bar .container { border-bottom: 1px solid #eee; padding-bottom: 16px; padding-top: 8px; }
  .filter-row { display: flex; align-items: center; flex-wrap: wrap; gap: 4px; }
  .filter-row-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #999;
    margin-right: 12px;
  }
  .filter-btn {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    background: none;
    border: none;
    padding: 6px 14px;
    cursor: pointer;
    transition: color 0.2s;
    border-bottom: 2px solid transparent;
  }
  .filter-btn:hover { color: #1C1714; }
  .filter-btn.active { color: #1C1714; border-bottom: 2px solid #B8432A; }

  /* ===== RESULTS INFO ===== */
  .results-info {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #bbb;
    padding: 24px 0 8px;
  }

  /* ===== PRODUCT GRID ===== */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding-bottom: 56px;
  }

  /* ===== PRODUCT CARD ===== */
  .product-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .product-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); border-color: #ddd; }
  .pc-img {
    height: 160px;
    background: #f7f3ed;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
  .product-card:hover .pc-img .img-placeholder { transform: scale(1.03); }
  .pc-cat-tag {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 3px;
  }
  .tag-tools    { background: #fdf0ed; color: #B8432A; }
  .tag-ingredients { background: #f0ebe6; color: #6B4C3B; }
  .tag-instant  { background: #f0f4f2; color: #4a7060; }
  .tag-books    { background: #f5f0e8; color: #8B6914; }
  .tag-digital  { background: #eef0f8; color: #3a5080; }

  .pc-body { padding: 14px 14px 10px; }
  .pc-brand {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B8432A;
    margin-bottom: 4px;
  }
  .pc-name {
    font-family: 'Source Serif 4', serif;
    font-size: 14px;
    font-weight: 500;
    color: #1C1714;
    line-height: 1.3;
    margin-bottom: 5px;
  }
  .pc-desc { font-size: 11px; color: #999; line-height: 1.55; margin-bottom: 0; }
  .pc-footer {
    padding: 10px 14px;
    border-top: 1px solid #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pc-price {
    font-family: 'Source Serif 4', serif;
    font-size: 14px;
    font-weight: 500;
    color: #1C1714;
  }
  .pc-shop {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B8432A;
    text-decoration: none;
    border-bottom: 1px solid rgba(184,67,42,0.3);
    padding-bottom: 1px;
  }

  /* ===== INLINE AD ===== */
  .inline-ad-wrap { padding: 8px 0 24px; }
  .inline-ad {
    height: 90px;
    border: 1px dashed #ccc;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #bbb;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ===== AFFILIATE NOTICE ===== */
  .affiliate-notice {
    max-width: 1100px;
    margin: 0 auto;
    padding: 12px 40px;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 0.04em;
    border-top: 1px solid #f5f5f5;
  }
  .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; padding: 16px 0 48px; }
  .pagination a, .pagination span { font-family: 'Inter', sans-serif; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #999; text-decoration: none; padding: 8px 14px; border: 1px solid #eee; border-radius: 4px; transition: all 0.2s; }
  .pagination a:hover { color: #1C1714; border-color: #1C1714; }
  .pagination .active { color: #1C1714; border-color: #1C1714; font-weight: 500; }
  .pagination .ellipsis { border: none; padding: 8px 4px; }
</style>

<script is:inline>
  function filterPantry(cat, btn) {
    document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');

    var cards = document.querySelectorAll('.product-card');
    var visible = 0;
    cards.forEach(function(card) {
      if (cat === 'all' || card.dataset.cat === cat) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    var countEl = document.getElementById('pantry-count');
    if (countEl) countEl.textContent = 'Showing ' + visible + ' product' + (visible !== 1 ? 's' : '');
  }
</script>
