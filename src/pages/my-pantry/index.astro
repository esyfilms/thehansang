            </div>
            <div class="fp-body">
              <div class="fp-brand">Brand Placeholder</div>
              <div class="fp-name">Product Placeholder</div>
              <div class="fp-desc">Description placeholder text.</div>
            </div>
            <div class="fp-footer">
              <div class="fp-price">Coming Soon</div>
              <span class="fp-cta">Shop Now &rarr;</span>
            </div>
          </a>

          <!-- FEATURED 2 -->
          <a href="#" target="_blank" class="featured-product">
