---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="My Pantry" description="My Pantry — Stock your Korean kitchen without leaving Singapore. Essential ingredients, tools, and where to shop.">

  <header class="page-header">
    <div class="page-header-korean" lang="ko">나의 식료품장</div>
    <h1>My Pantry</h1>
    <p class="page-header-desc">Stock your Korean kitchen without leaving Singapore.</p>
  </header>

  <section class="essentials" aria-label="Pantry essentials by category">
    <div class="essentials-grid">
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Sauces &amp; Pastes</div><div class="essential-card-desc">Gochujang, doenjang, soy sauce, and sesame oil</div><div class="essential-card-count">8 Essentials</div></a>
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Rice &amp; Grains</div><div class="essential-card-desc">Short-grain rice, sweet rice flour, and barley</div><div class="essential-card-count">5 Essentials</div></a>
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Noodles</div><div class="essential-card-desc">Dangmyeon, ramyeon, and knife-cut noodles</div><div class="essential-card-count">6 Essentials</div></a>
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Proteins &amp; Kimchi</div><div class="essential-card-desc">Kimchi, spam, dried anchovy, and tofu</div><div class="essential-card-count">7 Essentials</div></a>
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Vegetables &amp; Aromatics</div><div class="essential-card-desc">Gochugaru, garlic, ginger, and perilla</div><div class="essential-card-count">9 Essentials</div></a>
      <a href="#" class="essential-card"><div class="essential-card-image">[ photo ]</div><div class="essential-card-name">Tools &amp; Cookware</div><div class="essential-card-desc">Stone pot, scissors, chopsticks, and grill</div><div class="essential-card-count">6 Essentials</div></a>
    </div>
  </section>

  <section class="where-to-shop" aria-label="Where to shop in Singapore">
    <div class="where-to-shop-label">Where to Shop in Singapore</div>
    <div class="shop-links">
      <a href="#">Don Don Donki</a><span class="shop-divider" aria-hidden="true"></span>
      <a href="#">Korean Marts (Tanjong Pagar)</a><span class="shop-divider" aria-hidden="true"></span>
      <a href="#">FairPrice Finest</a><span class="shop-divider" aria-hidden="true"></span>
      <a href="#">Mustafa Centre</a><span class="shop-divider" aria-hidden="true"></span>
      <a href="#">Online (Shopee / Lazada)</a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header { padding: 80px 48px 72px; text-align: center; animation: fadeUp 0.6s ease-out 0.1s both; }
  .page-header-korean { font-family: 'Noto Serif KR', serif; font-size: 32px; font-weight: 200; color: var(--stone); margin-bottom: 4px; letter-spacing: 0.05em; }
  .page-header h1 { font-family: 'Source Serif 4', serif; font-size: 42px; font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  .page-header-desc { font-size: 16px; color: var(--gray-500); line-height: 1.7; max-width: 400px; margin: 0 auto; }
  .essentials { padding: 0 48px 80px; animation: fadeUp 0.6s ease-out 0.2s both; }
  .essentials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; max-width: 1080px; margin: 0 auto; }
  .essential-card { display: block; padding: 32px; border: 1px solid var(--stone); margin-right: -1px; margin-bottom: -1px; text-decoration: none; color: var(--ink); transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease; background: var(--cream); position: relative; }
  .essential-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(28, 23, 20, 0.06); border-color: var(--gray-400); z-index: 1; }
  .essential-card-image { width: 100%; aspect-ratio: 1 / 1; background: var(--linen); margin-bottom: 24px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--gray-400); letter-spacing: 0.08em; }
  .essential-card-name { font-family: 'Source Serif 4', serif; font-size: 19px; font-weight: 600; line-height: 1.3; margin-bottom: 6px; }
  .essential-card-desc { font-size: 16px; color: var(--gray-500); line-height: 1.6; margin-bottom: 16px; }
  .essential-card-count { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-400); }
  .where-to-shop { padding: 48px; text-align: center; border-top: 1px solid var(--stone); border-bottom: 1px solid var(--stone); animation: fadeUp 0.6s ease-out 0.3s both; }
  .where-to-shop-label { font-family: 'Outfit', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 24px; }
  .shop-links { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 0; }
  .shop-links a { font-size: 15px; color: var(--gray-500); text-decoration: none; transition: color 0.2s; padding: 4px 0; }
  .shop-links a:hover { color: var(--ink); }
  .shop-divider { width: 3px; height: 3px; background: var(--stone); border-radius: 50%; margin: 0 20px; flex-shrink: 0; }
  @media (max-width: 1024px) { .essentials-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .page-header { padding: 56px 24px 48px; }
    .page-header-korean { font-size: 26px; }
    .page-header h1 { font-size: 32px; }
    .essentials { padding: 0 24px 56px; }
    .essentials-grid { grid-template-columns: 1fr; max-width: 480px; }
    .essential-card { margin-right: 0; }
    .where-to-shop { padding: 36px 24px; }
    .shop-links { flex-direction: column; gap: 12px; }
    .shop-divider { display: none; }
  }
</style>
