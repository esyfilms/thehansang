---
import BaseLayout from '../../layouts/BaseLayout.astro';
let ads: any[] = [];
try { const m = await import('../../data/ads.json'); ads = m.default || []; } catch(e) { ads = []; }
const pageAd = ads.find((a: any) => a.placement === 'Pantry Leaderboard');
const inlineAd = ads.find((a: any) => a.placement === 'Category Inline');
---

<BaseLayout title="My Pantry" description="My Pantry — Stock your Korean kitchen without leaving Singapore. Essential ingredients, tools, and where to shop.">

  <!-- ========== MOBILE ========== -->
  <div class="mobile-only">

    <div class="cat-hd">
      <div class="cat-title">My Pantry</div>
      <div class="cat-sub">Stock your Korean kitchen without leaving Singapore</div>
    </div>

    <div class="filters-mobile">
      <button class="pill on">All</button>
      <button class="pill">Ingredients</button>
      <button class="pill">Kitchen Accessories</button>
      <button class="pill">Ceramics/Pottery</button>
      <button class="pill">Pots &amp; Pans</button>
      <button class="pill">Ramyeon</button>
      <button class="pill">Knives &amp; Chopping Boards</button>
    </div>

    <!-- Hero card (Eric's Top Pick) -->
    <a class="ch1" href="#">
      <div>
        <div class="ptag">Eric's Pick &middot; Kitchen</div>
        <div class="ch1-title">Product Placeholder</div>
        <div class="ch1-meta">Coming Soon</div>
      </div>
      <div class="ch1-img" style="background:linear-gradient(145deg,#d4a574,#a87b52);"></div>
    </a>

    <!-- 2x2 grid -->
    <div class="hgrid">
      <a class="hgc" href="#">
        <div class="hgc-img" style="background:linear-gradient(145deg,#c4564a,#8b3d34);"></div>
        <div class="ptag">Ingredient</div>
        <div class="hgc-title">Product Placeholder</div>
        <div class="hgc-meta">Coming Soon</div>
      </a>
      <a class="hgc" href="#">
        <div class="hgc-img" style="background:linear-gradient(145deg,#4a6b5a,#2e4a3a);"></div>
        <div class="ptag">Kitchen</div>
        <div class="hgc-title">Product Placeholder</div>
        <div class="hgc-meta">Coming Soon</div>
      </a>
      <a class="hgc" href="#">
        <div class="hgc-img" style="background:linear-gradient(145deg,#6b4c3b,#4a3428);"></div>
        <div class="ptag">Kitchen</div>
        <div class="hgc-title">Product Placeholder</div>
        <div class="hgc-meta">Coming Soon</div>
      </a>
      <a class="hgc" href="#">
        <div class="hgc-img" style="background:linear-gradient(145deg,#8B6914,#6b5010);"></div>
        <div class="ptag">Ingredient</div>
        <div class="hgc-title">Product Placeholder</div>
        <div class="hgc-meta">Coming Soon</div>
      </a>
    </div>

    <!-- Ad -->
    <div style="padding:12px 18px;">
      <div class="ad-rect">Ad &middot; 300 x 250</div>
    </div>

    <!-- List cards -->
    <a class="lc" href="#">
      <div>
        <div class="ptag">Instant</div>
        <div class="lc-title">Product Placeholder</div>
