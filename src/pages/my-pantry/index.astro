---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="My Pantry" description="My Pantry — Stock your Korean kitchen without leaving Singapore. Essential ingredients, tools, and where to shop.">

  <!-- Launch Banner -->
  <div class="launch-banner">
    We're launching soon — this is a design preview
  </div>

  <header class="page-header">
    <div class="page-header-korean" lang="ko">나의 식료품장</div>
    <h1>My Pantry</h1>
    <p class="page-header-desc">Stock your Korean kitchen without leaving Singapore.</p>
  </header>

  <!-- Category Grid -->
  <section class="pantry-grid-section">
    <div class="pantry-grid">
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Sauces &amp; Pastes</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Rice &amp; Grains</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Noodles &amp; Dried Goods</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Kimchi &amp; Fermented</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Snacks &amp; Drinks</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
      <a href="#" class="pantry-card">
        <div class="pantry-card-image">[ Image ]</div>
        <div class="pantry-card-title">Kitchen Tools</div>
        <div class="pantry-card-count">Coming Soon</div>
      </a>
    </div>
  </section>

  <!-- Where to Shop -->
  <section class="shop-bar">
    <div class="shop-bar-inner">
      <h2 class="shop-bar-title">Where to Shop</h2>
      <p class="shop-bar-desc">A guide to Korean grocery stores, online shops, and supermarket aisles in Singapore. Coming soon.</p>
    </div>
  </section>

</BaseLayout>

<style>
  .launch-banner { background: var(--ink); color: var(--cream); text-align: center; padding: 10px 24px; font-size: 13px; letter-spacing: 0.05em; }

  .page-header { padding: 80px 48px 72px; text-align: center; animation: fadeUp 0.6s ease-out 0.1s both; }
  .page-header-korean { font-family: 'Noto Serif KR', serif; font-size: 32px; font-weight: 200; color: var(--stone); margin-bottom: 4px; letter-spacing: 0.05em; }
  .page-header h1 { font-family: 'Source Serif 4', serif; font-size: 42px; font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  .page-header-desc { font-size: 16px; color: var(--gray-500); line-height: 1.7; max-width: 400px; margin: 0 auto; }

  /* Pantry Grid */
  .pantry-grid-section {
    padding: 48px;
    border-top: 1px solid var(--stone);
    animation: fadeUp 0.6s ease-out 0.2s both;
  }
  .pantry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
  }
  .pantry-card {
    display: block;
    text-decoration: none;
    color: var(--ink);
    border: 1px solid var(--stone);
    transition: all 0.2s;
    text-align: center;
  }
  .pantry-card:hover {
    border-color: var(--ink);
    background: var(--linen);
  }
  .pantry-card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--stone);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--gray-400);
  }
  .pantry-card-title {
    font-family: 'Source Serif 4', serif;
    font-size: 18px;
    font-weight: 600;
    padding: 20px 16px 4px;
  }
  .pantry-card-count {
    font-size: 12px;
    color: var(--gray-400);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0 16px 20px;
  }

  /* Where to Shop Bar */
  .shop-bar {
    padding: 48px;
    background: var(--linen);
    border-top: 1px solid var(--stone);
    border-bottom: 1px solid var(--stone);
    text-align: center;
    animation: fadeUp 0.6s ease-out 0.3s both;
  }
  .shop-bar-inner {
    max-width: 520px;
    margin: 0 auto;
  }
  .shop-bar-title {
    font-family: 'Source Serif 4', serif;
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .shop-bar-desc {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .page-header { padding: 56px 24px 48px; }
    .page-header-korean { font-size: 26px; }
    .page-header h1 { font-size: 32px; }
    .pantry-grid-section { padding: 32px 24px; }
    .pantry-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .shop-bar { padding: 36px 24px; }
  }
  @media (max-width: 480px) {
    .pantry-grid { grid-template-columns: 1fr; }
  }
</style>
