    </section>

    <hr class="section-divider">

    <!-- ===== AD SLOT ===== -->
    <div class="container">
      <div class="inline-ad-wrap">
        {pageAd ? (
          pageAd.bannerImages?.[0] ? (
            <a href={pageAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="inline-ad" style="display:block;text-align:center;border:none;background:none;">
              <img src={pageAd.bannerImages[0]} alt={pageAd.sponsorName || 'Partner'} style="max-width:728px;width:100%;height:auto;display:block;margin:0 auto;" />
            </a>
          ) : (
            <a href={pageAd.linkUrl || '#'} target="_blank" rel="noopener sponsored" class="inline-ad" style="display:flex;align-items:center;justify-content:center;gap:10px;text-decoration:none;background:#F7F3ED;border:1px solid #E0D8CE;padding:14px 24px;border-radius:4px;">
              <span style="font-family:'Inter',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#B8432A;">{pageAd.sponsorName}</span>
              <span style="font-family:'Inter',sans-serif;font-size:12px;color:#1C1714;letter-spacing:0.02em;">{pageAd.displayText}</span>
            </a>
          )
        ) : (
          <div class="inline-ad">Partner &middot; 728 &times; 90 &middot; Leaderboard</div>
        )}
      </div>
    </div>

    <!-- ===== FILTER BAR ===== -->
    <section class="filter-bar">
      <div class="container">
        <div class="filter-row">
          <span class="filter-row-label">Category</span>
          <button class="filter-btn active" onclick="filterPantry('all', this)">All</button>
          <button class="filter-btn" onclick="filterPantry('tools', this)">Kitchen Tools</button>
          <button class="filter-btn" onclick="filterPantry('ingredients', this)">Ingredients</button>
          <button class="filter-btn" onclick="filterPantry('instant', this)">Instant &amp; Packaged</button>
        </div>
      </div>
    </section>

    <!-- ===== PRODUCT GRID ===== -->
    <section>
      <div class="container">
        <div class="results-info" id="pantry-count">Showing 9 products</div>

        <div class="product-grid" id="pantry-grid">

          <!-- PRODUCT 1 - Kitchen Tools -->
          <a href="#" target="_blank" class="product-card" data-cat="tools">
