<style>
  .article-header { padding: 48px 48px 0; max-width: 900px; margin: 0 auto; animation: fadeUp 0.6s ease-out 0.1s both; }
  .article-pillar-tag { font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ember); margin-bottom: 16px; }
  .article-pillar-tag a { color: var(--ember); text-decoration: none; transition: color 0.2s; }
  .article-pillar-tag a:hover { color: var(--ink); }
  .article-header h1 { font-family: 'Source Serif 4', serif; font-size: 40px; font-weight: 700; line-height: 1.18; margin-bottom: 20px; text-wrap: balance; }
  .article-byline { display: flex; align-items: center; gap: 16px; font-size: 13px; color: var(--gray-500); margin-bottom: 32px; flex-wrap: wrap; }
  .article-byline .author { color: var(--ink); font-weight: 500; }
  .article-byline .separator { color: var(--stone); }
  .article-featured-image { width: 100%; max-width: 900px; margin: 0 auto 48px; padding: 0 48px; animation: fadeUp 0.6s ease-out 0.2s both; }
  .article-featured-image .image-placeholder { width: 100%; height: 480px; background: var(--stone); display: flex; align-items: center; justify-content: center; color: var(--gray-400); font-size: 16px; letter-spacing: 0.05em; }
  .article-featured-image figcaption { font-family: 'Outfit', sans-serif; font-size: 12px; color: var(--gray-400); margin-top: 10px; line-height: 1.5; }
  .article-video { max-width: 680px; margin: 32px auto; padding: 0 48px; }
  .article-video-inner { position: relative; width: 100%; max-width: 400px; margin: 0 auto; background: var(--linen); border: 1px solid var(--stone); overflow: hidden; }
  .article-video-placeholder { aspect-ratio: 9 / 16; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: var(--gray-400); font-size: 12px; letter-spacing: 0.08em; }
  .article-video-play { width: 48px; height: 48px; background: rgba(0,0,0,0.6); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .article-video-play::after { content: ''; display: block; width: 0; height: 0; border-style: solid; border-width: 8px 0 8px 14px; border-color: transparent transparent transparent white; margin-left: 3px; }
  .article-video-caption { text-align: center; font-size: 12px; color: var(--gray-400); margin-top: 12px; font-style: italic; }
  .article-video-caption a { color: var(--ember); text-decoration: none; }
  .article-layout { display: grid; grid-template-columns: 1fr 300px; gap: 48px; max-width: 1100px; margin: 0 auto; padding: 0 48px 64px; animation: fadeUp 0.6s ease-out 0.3s both; }
  .article-content { max-width: 680px; }
  .article-content p { font-family: 'Source Serif 4', serif; font-size: 18px; line-height: 1.8; margin-bottom: 24px; color: var(--ink); }
  .article-content h2 { font-family: 'Source Serif 4', serif; font-size: 26px; font-weight: 700; line-height: 1.3; margin-top: 48px; margin-bottom: 20px; }
  .article-content h3 { font-family: 'Source Serif 4', serif; font-size: 20px; font-weight: 600; line-height: 1.35; margin-top: 36px; margin-bottom: 16px; }
  .article-content strong { font-weight: 600; }
  .article-content a { color: var(--ember); text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s; }
  .article-content a:hover { color: var(--ink); }
  .inline-photo { margin: 36px 0; }
  .inline-photo .image-placeholder { width: 100%; height: 360px; background: var(--stone); display: flex; align-items: center; justify-content: center; color: var(--gray-400); font-size: 16px; letter-spacing: 0.05em; }
  .inline-photo figcaption { font-family: 'Outfit', sans-serif; font-size: 12px; color: var(--gray-400); margin-top: 10px; line-height: 1.5; }
  .quick-take { border: 1.5px solid var(--stone); padding: 28px 32px; margin-bottom: 40px; background: #fff; }
  .quick-take-title { font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--stone); }
  .quick-take-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px 32px; }
  .quick-take-item { display: flex; flex-direction: column; gap: 4px; }
  .quick-take-label { font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray-400); }
  .quick-take-value { font-family: 'Source Serif 4', serif; font-size: 16px; font-weight: 600; color: var(--ink); }
  .quick-take-value.rating { color: var(--ember); font-size: 20px; }
  .dish-name { font-weight: 600; }
  .dish-price { font-family: 'Outfit', sans-serif; font-size: 14px; color: var(--gray-400); }
  .info-block { border: 1.5px solid var(--stone); padding: 28px 32px; margin-top: 48px; margin-bottom: 48px; background: #fff; }
  .info-block-title { font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--stone); }
  .info-block dl { display: grid; grid-template-columns: 120px 1fr; gap: 12px 16px; }
  .info-block dt { font-family: 'Outfit', sans-serif; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray-400); padding-top: 2px; }
  .info-block dd { font-family: 'Source Serif 4', serif; font-size: 16px; line-height: 1.6; color: var(--ink); }
  .verdict { margin-top: 48px; padding-top: 32px; border-top: 1.5px solid var(--stone); }
  .verdict h2 { margin-top: 0; }
  .verdict-rating { font-family: 'Source Serif 4', serif; font-size: 48px; font-weight: 700; color: var(--ember); margin-bottom: 16px; }
  .verdict-rating span { font-size: 24px; color: var(--gray-400); font-weight: 400; }
  .verdict-summary { font-family: 'Source Serif 4', serif; font-size: 17px; line-height: 1.8; color: var(--gray-500); font-style: italic; }
  .ad-sidebar { position: relative; }
  .ad-sidebar-inner { position: sticky; top: 90px; display: flex; flex-direction: column; gap: 32px; }
  .ad-slot { width: 300px; height: 250px; border: 2px dashed var(--stone); display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--gray-400); font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; background: #fff; }
  .ad-slot-label { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-400); border: 1px solid var(--stone); padding: 1px 6px; margin-bottom: 8px; }
  .ad-inline { display: none; margin: 36px 0; }
  .ad-inline .ad-slot { width: 100%; max-width: 400px; margin: 0 auto; }
  .more-from { max-width: 1100px; margin: 0 auto; padding: 0 48px 64px; border-top: 1px solid var(--stone); animation: fadeUp 0.6s ease-out 0.4s both; }
  .more-from-header { display: flex; justify-content: space-between; align-items: baseline; padding: 32px 0 24px; }
  .more-from-title { font-family: 'Source Serif 4', serif; font-size: 22px; font-weight: 600; }
  .more-from-link { font-family: 'Outfit', sans-serif; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray-500); text-decoration: none; transition: color 0.2s; }
  .more-from-link:hover { color: var(--ink); }
  .more-from-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .related-card { padding: 0 24px; border-right: 1px solid var(--stone); text-decoration: none; color: var(--ink); transition: opacity 0.2s; }
  .related-card:first-child { padding-left: 0; }
  .related-card:last-child { padding-right: 0; border-right: none; }
  .related-card:hover { opacity: 0.75; }
  .related-card-image { width: 100%; height: 180px; background: var(--stone); display: flex; align-items: center; justify-content: center; color: var(--gray-400); font-size: 13px; margin-bottom: 14px; }
  .related-card-pillar { font-family: 'Outfit', sans-serif; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 8px; }
  .related-card-title { font-family: 'Source Serif 4', serif; font-size: 17px; font-weight: 600; line-height: 1.35; margin-bottom: 8px; }
  .related-card-excerpt { font-size: 13px; color: var(--gray-500); line-height: 1.55; margin-bottom: 10px; }
  .related-card-meta { font-family: 'Outfit', sans-serif; font-size: 11px; color: var(--gray-400); letter-spacing: 0.04em; }
  @media (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr; gap: 0; }
    .ad-sidebar { display: none; }
    .ad-inline { display: block; }
    .more-from-grid { grid-template-columns: 1fr 1fr; }
    .related-card:last-child { display: none; }
    .related-card:nth-child(2) { border-right: none; }
  }
  @media (max-width: 768px) {
    .article-header { padding: 32px 24px 0; }
    .article-header h1 { font-size: 30px; }
    .article-byline { gap: 8px; }
    .article-featured-image { padding: 0; margin-bottom: 36px; }
    .article-featured-image .image-placeholder { height: 280px; }
    .article-layout { padding: 0 24px 48px; }
    .article-content p { font-size: 17px; }
    .article-content h2 { font-size: 22px; margin-top: 36px; }
    .article-video { padding: 0 24px; }
    .inline-photo .image-placeholder { height: 240px; }
    .info-block dl { grid-template-columns: 1fr; gap: 4px; }
    .info-block dt { padding-top: 8px; }
    .more-from { padding: 0 24px 48px; }
    .more-from-grid { grid-template-columns: 1fr; }
    .related-card { padding: 16px 0; border-right: none; border-bottom: 1px solid var(--stone); }
    .related-card:last-child { display: block; border-bottom: none; }
  }
  @media (max-width: 480px) {
    .article-header h1 { font-size: 26px; }
    .quick-take-grid { grid-template-columns: 1fr; }
  }
</style>

<style>
  .related-posts-inline { border: 1.5px solid var(--stone); padding: 28px 32px; margin-top: 48px; margin-bottom: 48px; background: #fff; }
  .related-posts-inline-title { font-family: 'Outfit', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--stone); }
  .related-posts-inline ul { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .related-posts-inline a { font-family: 'Source Serif 4', serif; font-size: 16px; font-weight: 600; color: var(--ink); text-decoration: none; transition: color 0.2s; display: block; }
  .related-posts-inline a:hover { color: var(--ember); }
  .related-post-meta { font-family: 'Outfit', sans-serif; font-size: 12px; color: var(--gray-400); margin-top: 4px; }
</style>
