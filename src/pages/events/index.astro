---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Events" description="Korean festivals, pop-ups, markets, and workshops happening in Singapore. The Hansang.">

  <section class="category-title-bar">
    <div class="container">
      <h1>Events <span class="soon-badge-d">Coming Soon</span></h1>
      <div class="title-sub">Korean festivals, pop-ups, markets &amp; workshops in Singapore</div>
    </div>
  </section>

  <div class="cs-body">
    <h2>Events calendar is coming</h2>
    <p>Korean festivals, pop-up markets, food workshops, and cultural events happening across Singapore.</p>
    <div class="cs-tag">Check back soon</div>
  </div>

</BaseLayout>

<style>
  .category-title-bar { background: #FFFFFF; padding: 16px 0; }
  .category-title-bar .container { background: #1C1714; padding: 28px 40px; max-width: 1020px; margin: 0 auto; }
  .category-title-bar h1 { font-family: 'Source Serif 4', serif; font-size: 32px; font-weight: 600; color: #FFFFFF; letter-spacing: 0.14em; text-transform: uppercase; line-height: normal; margin-bottom: 0; }
  .category-title-bar .title-sub { font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 0.16em; font-weight: 300; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 6px; }
  .soon-badge-d { font-family: 'Inter', sans-serif; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #B8432A; border: 1px solid #B8432A; padding: 3px 10px; border-radius: 3px; vertical-align: middle; margin-left: 12px; }
  .cs-body { text-align: center; padding: 120px 40px; max-width: 600px; margin: 0 auto; }
  .cs-body h2 { font-family: 'Source Serif 4', serif; font-size: 22px; font-weight: 500; color: #1C1714; margin-bottom: 12px; }
  .cs-body p { font-family: 'Inter', sans-serif; font-size: 14px; color: #888; line-height: 1.6; margin-bottom: 24px; }
  .cs-tag { font-family: 'Inter', sans-serif; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #bbb; }
</style>
