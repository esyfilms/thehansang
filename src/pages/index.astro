---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Everything Korea, for Singapore" description="The Hansang — Everything Korea, for Singapore. Korean food reviews, recipes, travel guides, and culture.">

  <!-- Launch Banner -->
  <div class="launch-banner">
    We're launching soon — this is a design preview
  </div>

  <!-- ===== HERO — Featured Post (Notion: Featured checkbox) ===== -->
  <a href="/thehansang/eat/design-preview/" class="hero" style="text-decoration:none;color:inherit;display:block;">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-label">Featured</span>
        <h1>Article Title Placeholder for the Featured Story</h1>
        <p class="hero-excerpt">Short description placeholder text goes here. This will be replaced with a real featured article excerpt when the site launches.</p>
        <span class="hero-meta">Coming Soon &middot; 8 min read</span>
      </div>
      <div class="hero-image">[ Featured Image ]</div>
    </div>
  </a>

  <!-- ===== KOREAN EATS — Eat pillar only ===== -->
  <section class="articles" aria-label="Korean Eats">
    <div class="section-header">
      <h2 class="section-title">Korean Eats</h2>
      <a href="/thehansang/eat/" class="view-all">View All</a>
    </div>
    <div class="carousel-wrap">
      <div class="articles-grid">
        <a href="/thehansang/eat/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Eat &middot; Review</div>
          <div class="article-title">Restaurant Review Placeholder</div>
          <div class="article-excerpt">A placeholder for a restaurant review.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
        <a href="/thehansang/eat/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Eat &middot; Guide</div>
          <div class="article-title">Guide Title Placeholder</div>
          <div class="article-excerpt">A placeholder for an eating guide.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
        <a href="/thehansang/eat/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Eat &middot; Versus</div>
          <div class="article-title">Comparison Title Placeholder</div>
          <div class="article-excerpt">A placeholder for a versus post.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
        <a href="/thehansang/eat/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Eat &middot; New Opening</div>
          <div class="article-title">New Opening Placeholder</div>
          <div class="article-excerpt">A placeholder for a new opening.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FROM THE KITCHEN — Cook pillar (DARK BAND) ===== -->
  <section class="articles recipe-band" aria-label="From the Kitchen">
    <div class="section-header">
      <h2 class="section-title">From the Kitchen</h2>
      <a href="/thehansang/cook/" class="view-all">View All</a>
    </div>
    <div class="carousel-wrap">
      <div class="articles-grid">
        <a href="/thehansang/cook/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Cook &middot; Main</div>
          <div class="article-title">Recipe Title Placeholder</div>
          <div class="article-excerpt">Description coming soon.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
        <a href="/thehansang/cook/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Cook &middot; Side</div>
          <div class="article-title">Recipe Title Placeholder</div>
          <div class="article-excerpt">Description coming soon.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
        <a href="/thehansang/cook/design-preview/" class="article-card">
          <div class="article-image">[ Image ]</div>
          <div class="article-pillar">Cook &middot; Soup</div>
          <div class="article-title">Recipe Title Placeholder</div>
          <div class="article-excerpt">Description coming soon.</div>
          <div class="article-meta">Coming Soon</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== EDITOR'S PICK BANNER ===== -->
  <a href="/thehansang/eat/design-preview/" class="featured-banner" aria-label="Editor's Pick" style="text-decoration:none;color:inherit;display:grid;">
    <div class="featured-banner-image">[ Featured Image ]</div>
    <div class="featured-banner-text">
      <span class="featured-banner-label">Editor's Pick</span>
      <div class="featured-banner-title">Featured Story Title Coming Soon</div>
      <p class="featured-banner-excerpt">This space will feature a curated article. Controlled from Notion — check the Homepage Banner field to place a post here.</p>
      <span class="featured-banner-cta" style="opacity:0.5;">Coming Soon</span>
    </div>
  </a>

  <!-- ===== ON VIDEO (Carousel) ===== -->
  <section class="articles" aria-label="On Video">
    <div class="section-header">
      <h2 class="section-title">On Video</h2>
      <a href="https://www.instagram.com/thehansang.sg" class="view-all" target="_blank" rel="noopener">More Videos</a>
    </div>
    <div class="carousel-wrap">
      <div class="articles-grid video-carousel">
        <a href="https://www.instagram.com/thehansang.sg" target="_blank" rel="noopener" class="video-carousel-card">
          <div class="video-thumb"><div class="video-play"></div></div>
          <div class="video-platform">Instagram Reel</div>
          <div class="video-title">Video Title Placeholder</div>
        </a>
        <a href="https://www.instagram.com/thehansang.sg" target="_blank" rel="noopener" class="video-carousel-card">
          <div class="video-thumb"><div class="video-play"></div></div>
          <div class="video-platform">Instagram Reel</div>
          <div class="video-title">Video Title Placeholder</div>
        </a>
        <a href="https://www.instagram.com/thehansang.sg" target="_blank" rel="noopener" class="video-carousel-card">
          <div class="video-thumb"><div class="video-play"></div></div>
          <div class="video-platform">Instagram Reel</div>
          <div class="video-title">Video Title Placeholder</div>
        </a>
        <a href="https://www.instagram.com/thehansang.sg" target="_blank" rel="noopener" class="video-carousel-card">
          <div class="video-thumb"><div class="video-play"></div></div>
          <div class="video-platform">Instagram Reel</div>
          <div class="video-title">Video Title Placeholder</div>
        </a>
        <a href="https://www.instagram.com/thehansang.sg" target="_blank" rel="noopener" class="video-carousel-card">
          <div class="video-thumb"><div class="video-play"></div></div>
          <div class="video-platform">Instagram Reel</div>
          <div class="video-title">Video Title Placeholder</div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .launch-banner {
    background: var(--ink);
    color: var(--cream);
    text-align: center;
    padding: 10px 24px;
    font-size: 13px;
    letter-spacing: 0.05em;
  }

  /* Video carousel cards */
  .video-carousel-card {
    flex: 0 0 200px !important;
    min-width: 200px !important;
    padding: 20px 16px;
    text-decoration: none;
    color: var(--ink);
    scroll-snap-align: start;
  }

  .video-carousel-card .video-thumb {
    aspect-ratio: 9 / 16;
    background: var(--stone);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .video-carousel-card .video-play {
    width: 40px;
    height: 40px;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-carousel-card .video-play::after {
    content: '';
    display: block;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 7px 0 7px 12px;
    border-color: transparent transparent transparent white;
    margin-left: 3px;
  }

  .video-carousel-card .video-platform {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 4px;
  }

  .video-carousel-card .video-title {
    font-family: 'Source Serif 4', serif;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .video-carousel-card {
      flex: 0 0 160px !important;
      min-width: 160px !important;
      padding: 16px 12px;
    }
    .video-carousel-card .video-title { font-size: 13px; }
  }
</style>
